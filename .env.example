# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram Chat ID (send /start to @userinfobot to find yours)
TELEGRAM_CHAT_ID=your_chat_id_here

# Notion Integration Token (from https://www.notion.so/my-integrations)
NOTION_TOKEN=secret_your_notion_integration_token_here

# Notion Database IDs (share each DB with your integration, then copy the ID from the URL)
NOTION_PORTFOLIO_DB_ID=your_portfolio_database_id_here
NOTION_TRADES_DB_ID=your_trades_database_id_here
NOTION_WATCHLIST_DB_ID=your_watchlist_database_id_here
NOTION_DECISION_LOG_DB_ID=your_decision_log_database_id_here

# Scheduler time (24h format, system local time)
DAILY_REPORT_HOUR=8
DAILY_REPORT_MINUTE=0
